# HealthyU — environment template. Copy to .env and fill values.
# DO NOT commit a real .env. Secrets at runtime are managed via Lovable Cloud
# project secrets, not via committed files.

# --- Public (client-safe, shipped in browser bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Server-only secrets ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI gateway (auto-provisioned by Lovable in hosted environments)
LOVABLE_API_KEY=

# Shared secret for /api/public/hooks/* cron endpoints (min 32 chars).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Web Push (VAPID)
VAPID_SUBJECT=
VAPID_PRIVATE_KEY=

# Google Fit OAuth
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=