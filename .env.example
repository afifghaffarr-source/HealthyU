# HealthyU - environment template. Copy to .env and fill values.
# DO NOT commit a real .env. Secrets at runtime are managed via Cloudflare Pages
# environment variables (and locally via .env for dev), not via committed files.

# --- Public (client-safe, shipped in browser bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Server-only secrets ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# VexoAPI AI gateway. See https://vexoapi.site (migrated from vexoapi.dev in 2026-06).
# Generate free key at https://vexoapi.site (or legacy https://vexoapi.azzamcodex.site).
# IMPORTANT: free tier endpoints may return 403 ("upstream denied") during
# upstream model outages. Rotate key or switch provider if persistent.
# OpenAI-compatible: POST {VEXO_BASE_URL}/api/v1/chat/completions with Bearer auth.
VEXO_API_KEY=
VEXO_BASE_URL=https://vexoapi.site

# Shared secret for /api/public/hooks/ cron endpoints (min 32 chars).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Web Push (VAPID)
VAPID_SUBJECT=
VAPID_PRIVATE_KEY=

# Google Fit OAuth
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
