  "scripts": {
    "dev": "vite dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 vite build && bun run build:sw",
    "build:sw": "bunx esbuild src/sw.ts --bundle --format=iife --minify --target=es2020 --outfile=dist/client/sw.js",
    "build:dev": "NODE_OPTIONS=--max-old-space-size=4096 vite build --mode development",
    "deploy": "bun run build && wrangler deploy",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:constants": "eslint src/lib/constants.ts",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "precommit": "bun run lint:constants && bun run lint && bun run typecheck",
    "test": "NODE_OPTIONS=--max-old-space-size=4096 vitest run",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=4096 vitest",
    "verify": "bun run typecheck && bun run test && bun run build",
    "format": "prettier --write .",
    "i18n:scan": "node scripts/i18n-scan.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "analyze": "NODE_OPTIONS=--max-old-space-size=4096 ANALYZE=1 vite build && echo '\\n📊 Open dist/bundle-stats.html in your browser'",
