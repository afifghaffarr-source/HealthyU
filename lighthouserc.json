{
  "ci": {
    "collect": {
      "startServerCommand": "bunx vite preview --port 4173 --strictPort",
      "startServerReadyPattern": "Local:",
      "url": ["http://localhost:4173/", "http://localhost:4173/auth", "http://localhost:4173/scan"],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": [
          "uses-http2",
          "canonical",
          "aria-hidden-focus",
          "color-contrast",
          "valid-source-maps",
          "errors-in-console",
          "lcp-lazy-loaded",
          "non-composited-animations",
          "prioritize-lcp-image",
          "unused-javascript",
          "uses-text-compression"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": "off",
        "categories:accessibility": "off",
        "categories:best-practices": "off",
        "categories:seo": "off",
        "csp-xss": "off",
        "is-on-https": "off",
        "redirects-http": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
