{
  "ci": {
    "collect": {
      "startServerCommand": "set -a && . ./.dev.vars && set +a && exec bunx vite preview --port 4173 --strictPort",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/auth",
        "http://localhost:4173/scan",
        "http://localhost:4173/artikel",
        "http://localhost:4173/faq"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "skipAudits": [
          "uses-http2",
          "canonical",
          "errors-in-console",
          "lcp-lazy-loaded",
          "prioritize-lcp-image",
          "unused-javascript",
          "uses-text-compression"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:best-practices": ["warn", { "minScore": 0.8 }],
        "categories:seo": ["warn", { "minScore": 0.8 }],
        "csp-xss": "off",
        "is-on-https": "off",
        "redirects-http": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
