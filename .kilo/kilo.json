{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": ["AGENTS.md", "healthyu-project-rules.md"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "bun run dev": "allow",
      "bun run test": "allow",
      "bun run lint": "allow",
      "bunx tsc --noEmit": "allow",
      "bun run build": "allow",
      "bun run preview": "allow",
      "bun run e2e": "allow",
      "git status": "allow",
      "git diff": "allow",
      "git log": "allow",
      "git branch": "allow",
      "*": "ask"
    },
    "edit": {
      "src/**": "ask",
      ".kilo/**": "ask",
      "AGENTS.md": "ask",
      "*.md": "ask",
      ".env*": "deny",
      "*.lock": "deny",
      "package.json": "ask",
      "*": "ask"
    },
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "external_directory": "deny"
  },
  "snapshot": true
}
